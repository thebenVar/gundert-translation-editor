\grk ῥομφαία
\trl rhomfaia
\ref G04200203500016 G06600101600030 G06600201200028 G06600201600030 G06600600800066 G06601901500014 G06601902100014 L06800101200066 L06800202700086 L06800701400038 L06800801900010 L06800900200024 L06801101000054 L06801600400024  L07000502000012 L07102100300004 L07102202100010 L07102602800066 L07103903000016 L07104000900014 L07104600200024 L07200202500046 L07500105900040 L07700200900040 L07700300300050 L07700401500014 L07700403300006 L07700502800048 L07700505100014 L07700703800030 L07700704600042 L07700802300038 L07700907300006 L07701204800046 L07801501500018 L07801501600008 L08100105000014 L08100105300026 L08100402300010 L08100807400060 L08601300200014 L08601500700006
